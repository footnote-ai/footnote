{
    "name": "@footnote/agent-runtime",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./voltagentRuntime": {
            "types": "./dist/voltagentRuntime.d.ts",
            "default": "./dist/voltagentRuntime.js"
        }
    },
    "scripts": {
        "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true});\"",
        "build:dev": "tsc -b tsconfig.json",
        "build": "pnpm clean && tsc -b tsconfig.json"
    },
    "devDependencies": {
        "typescript": "catalog:"
    },
    "dependencies": {
        "@footnote/contracts": "workspace:*",
        "@voltagent/core": "2.6.13",
        "ai": "6.0.140",
        "openai": "catalog:",
        "ws": "catalog:"
    }
}
