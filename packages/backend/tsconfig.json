{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "dist",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "baseUrl": ".",
        "paths": {
            "@footnote/config-spec": ["../config-spec/dist/index.d.ts"],
            "@footnote/config-spec/*": ["../config-spec/dist/*"],
            "@footnote/contracts": ["../contracts/src/index.ts"],
            "@footnote/contracts/*": ["../contracts/src/*"],
            "@footnote/prompts": ["../prompts/dist/index.d.ts"],
            "@footnote/prompts/*": ["../prompts/dist/*"]
        },
        "types": ["node"],
        "noEmitOnError": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
