{
    "name": "@footnote/backend",
    "private": true,
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "build": "pnpm --dir ../.. --filter @footnote/config-spec run build && pnpm --dir ../.. --filter @footnote/prompts run build && tsc -p tsconfig.json"
    },
    "dependencies": {
        "@footnote/config-spec": "workspace:*",
        "@footnote/contracts": "workspace:*",
        "@footnote/prompts": "workspace:*",
        "@resvg/resvg-js": "catalog:",
        "better-sqlite3": "catalog:",
        "dotenv": "catalog:",
        "winston-daily-rotate-file": "catalog:",
        "zod": "catalog:",
        "winston": "catalog:"
    },
    "devDependencies": {
        "@types/better-sqlite3": "catalog:",
        "@types/node": "catalog:",
        "typescript": "catalog:"
    }
}
