{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "@footnote/prompts": ["../prompts/dist/index.d.ts"],
            "@footnote/prompts/*": ["../prompts/dist/*"]
        },
        "typeRoots": ["./node_modules/@types", "./src/types"],
        "sourceMap": true,
        "declaration": true,
        "resolveJsonModule": true
    },
    "references": [
        { "path": "../contracts" },
        { "path": "../config-spec" },
        { "path": "../prompts" }
    ],
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
