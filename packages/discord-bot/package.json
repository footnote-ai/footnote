{
    "name": "@footnote/discord-bot",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "exports": {
        ".": "./dist/index.js",
        "./src/utils/openaiService.js": "./dist/src/utils/openaiService.js",
        "./src/utils/response/metadata.js": "./dist/src/utils/response/metadata.js",
        "./src/utils/RateLimiter.js": "./dist/src/utils/RateLimiter.js"
    },
    "scripts": {
        "prestart": "pnpm build",
        "start": "node --es-module-specifier-resolution=node dist/index.js",
        "predev": "pnpm --dir ../.. --filter @footnote/config-spec run build:dev && pnpm --dir ../.. --filter @footnote/prompts run build:dev",
        "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
        "build": "pnpm clean && pnpm --dir ../.. --filter @footnote/config-spec run build && pnpm --dir ../.. --filter @footnote/prompts run build && tsc -b tsconfig.json",
        "clean": "rimraf dist",
        "watch": "tsc -b -w"
    },
    "dependencies": {
        "@footnote/config-spec": "workspace:*",
        "@footnote/contracts": "workspace:*",
        "@footnote/prompts": "workspace:*",
        "@discordjs/voice": "catalog:",
        "@openai/agents": "catalog:",
        "@sapphire/shapeshift": "catalog:",
        "body-parser": "catalog:",
        "cloudinary": "catalog:",
        "date-fns": "catalog:",
        "discord.js": "catalog:",
        "dotenv": "catalog:",
        "express": "catalog:",
        "flyio": "catalog:",
        "linkify-it": "^5.0.0",
        "mime-types": "catalog:",
        "node-fetch": "catalog:",
        "only": "catalog:",
        "openai": "catalog:",
        "opusscript": "catalog:",
        "prism-media": "catalog:",
        "reindex": "catalog:",
        "remark-parse": "^11.0.0",
        "unified": "^11.0.5",
        "unist-util-visit": "^5.0.0",
        "winston": "catalog:",
        "winston-daily-rotate-file": "catalog:",
        "ws": "catalog:"
    },
    "devDependencies": {
        "@types/body-parser": "catalog:",
        "@types/express": "catalog:",
        "@types/linkify-it": "^5.0.0",
        "@types/mdast": "^4.0.4",
        "@types/node": "catalog:",
        "@types/unist": "^3.0.3",
        "cross-env": "catalog:",
        "rimraf": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:"
    }
}
